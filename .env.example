# OpenAI
OPENAI_API_KEY=sk-...

# Path ke database bantukos-bot (di-mount dari container bantukos-bot)
BANTUKOS_DB_PATH=data/bantukos.db

# Nama owner yang akan disebut bot saat eskalasi
OWNER_NAME=Yuga

# Nomor HP pribadi kamu (tanpa + atau 0 di depan, pakai 62)
# Pesan dari nomor ini akan diperlakukan sebagai admin command
OWNER_NUMBER=62xxxxxxxxxxx

# (Opsional) Nomor tujuan notifikasi sistem (disk alert, outreach lead, dll.)
# Kalau diisi, notifikasi dikirim ke nomor ini sebagai pesan MASUK → ada sound di iPhone
# Kalau kosong, notifikasi dikirim ke Saved Messages (bot ke diri sendiri, no sound)
OWNER_NOTIFY_NUMBER=62xxxxxxxxxxx
